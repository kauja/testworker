# --- Runner ---
# 起点 URL（CLI で上書き可）
START_URL=http://host.docker.internal:3000

# クロール挙動
MAX_DEPTH=3
MAX_PAGES=50
SAME_ORIGIN_ONLY=true
NAV_TIMEOUT_MS=15000
WAIT_AFTER_NAV_MS=500

# 認証: 事前生成した storage state を使う場合のパス（コンテナ内）
# 例: /data/auth/storage-state.json
STORAGE_STATE_PATH=

# 認証: ログインスクリプト（コンテナ内パス、未指定なら未使用）
# 例: /workspace/packages/runner/auth/login.ts
LOGIN_SCRIPT_PATH=

# --- Api ---
API_PORT=3001
DB_PATH=/data/db/testworker.sqlite
DATA_DIR=/data

# --- Web ---
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
