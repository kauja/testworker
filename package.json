{
  "name": "testworker",
  "private": true,
  "version": "0.1.0",
  "description": "Web app crawler that captures console/network/errors and renders the screen transition graph.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "format": "prettier --write .",
    "db:migrate": "pnpm --filter @testworker/runner run db:migrate",
    "crawl": "pnpm --filter @testworker/runner run crawl"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
