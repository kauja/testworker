{
  "name": "@testworker/runner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "testworker-runner": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc && cp -R src/db/migrations dist/db/",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "crawl": "tsx src/cli.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "purge": "tsx src/db/purge.ts"
  },
  "dependencies": {
    "@testworker/shared": "workspace:*",
    "better-sqlite3": "^11.3.0",
    "playwright": "^1.49.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "tsx": "^4.19.2"
  }
}
